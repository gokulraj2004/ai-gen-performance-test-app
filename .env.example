# ═══════════════════════════════════════════════════════════════
# Performance Test App — Environment Variables
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and update values for your environment.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
APP_NAME=Performance Test App
APP_ENV=development
DEBUG=true
# Used for general application signing; generate with: openssl rand -hex 32
SECRET_KEY=<GENERATE_WITH: openssl rand -hex 32>

# ── Backend ──────────────────────────────────────────────────
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ── Database ─────────────────────────────────────────────────
DB_HOST=db
DB_PORT=5432
DB_NAME=performance_test_app
DB_USER=postgres
# Generate a strong password; e.g.: openssl rand -base64 24
DB_PASSWORD=<GENERATE_A_STRONG_PASSWORD>
# Async URL used by SQLAlchemy (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}
# Sync URL used by Alembic migrations
DATABASE_URL_SYNC=postgresql://${DB_USER}:${DB_PASSWORD}@${DB_HOST}:${DB_PORT}/${DB_NAME}

# ── Authentication (JWT) ─────────────────────────────────────
# Generate with: openssl rand -hex 32
JWT_SECRET_KEY=<GENERATE_WITH: openssl rand -hex 32>
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
JWT_ALGORITHM=HS256

# ── Frontend ─────────────────────────────────────────────────
# Base URL the frontend uses to call the backend API
VITE_API_BASE_URL=http://localhost:8000/api/v1

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:5173